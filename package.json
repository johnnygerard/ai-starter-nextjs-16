{
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^16.2.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24"
    }
  },
  "name": "ai-starter-nextjs-16",
  "private": true,
  "scripts": {
    "build": "next build",
    "deploy:preview": "vercel pull --environment=preview && vercel build && vercel deploy --prebuilt",
    "deploy:production": "vercel pull --environment=production && vercel build --prod && vercel deploy --prebuilt --prod",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "next": "next",
    "start": "serve out -l 3001"
  },
  "type": "module",
  "version": "0.0.0"
}
